{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "spring-boot:run app (local)",
      "type": "shell",
      "command": "mvn -pl app spring-boot:run -Dspring-boot.run.profiles=local",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
